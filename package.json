{
  "name": "loki",
  "version": "0.1.0",
  "description": "Cross-platform clipboard history manager with global hotkeys, system tray and persistent storage.",
  "main": "dist-electron/main/index.js",
  "author": "Loki Contributors",
  "license": "MIT",
  "private": true,
  "scripts": {
    "build:main": "tsc -p tsconfig.main.json",
    "build:preload": "node scripts/build-preload.mjs",
    "build:renderer": "vite build",
    "build:all": "npm run build:main && npm run build:preload && npm run build:renderer",
    "typecheck": "tsc -p tsconfig.main.json --noEmit && tsc -p tsconfig.renderer.json --noEmit && tsc -p tsconfig.test.json",
    "start": "npm run build:all && electron .",
    "dev": "npm run build:all && electron . --enable-logging",
    "test": "tsx --test tests/clipboard-monitor.test.ts tests/history-store.test.ts tests/modifier-watcher.test.ts tests/settings.test.ts",
    "build": "npm run build:all && electron-builder",
    "build:win": "npm run build:all && electron-builder --win",
    "build:linux": "npm run build:all && electron-builder --linux",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "uiohook-napi": "^1.5.4"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "electron": "^31.3.1",
    "electron-builder": "^24.13.3",
    "postcss": "^8.4.40",
    "tailwindcss": "^3.4.7",
    "tsx": "^4.19.0",
    "typescript": "^5.5.4",
    "vite": "^5.4.0"
  },
  "build": {
    "appId": "co.monalee.loki",
    "productName": "Loki",
    "directories": {
      "output": "dist"
    },
    "files": [
      "dist-electron/**/*",
      "resources/**/*",
      "package.json"
    ],
    "extraResources": [
      "resources/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "icon": "resources/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "linux": {
      "target": [
        "deb",
        "AppImage"
      ],
      "category": "Utility",
      "icon": "resources/icon.png",
      "synopsis": "Clipboard history manager",
      "description": "Cross-platform clipboard manager that records what you copy and lets you navigate the history with global hotkeys.",
      "maintainer": "Marcelo Boff <marcelo.boff@monalee.co>"
    },
    "deb": {
      "depends": [
        "libgtk-3-0",
        "libnotify4",
        "libnss3",
        "libxss1",
        "libxtst6",
        "xdg-utils",
        "libatspi2.0-0"
      ]
    }
  }
}
